# =============================================================
# Trading Bot — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================

# --- Shioaji (Sinopac) ---
SHIOAJI_API_KEY=
SHIOAJI_SECRET_KEY=
SHIOAJI_SIMULATION=false   # true = use Sinopac paper trading
SHIOAJI_RUNTIME_DIR=.tmp/shioaji_runtime
SHIOAJI_FUTURES_SYMBOL=TMF
SHIOAJI_POINT_VALUE=10
SHIOAJI_ENABLE_QUOTE_MONITOR=true
SHIOAJI_QUOTE_STALE_SECONDS=15
SHIOAJI_PROTECTIVE_WATCHDOG_INTERVAL=5
SHIOAJI_PROTECTIVE_EXIT_PRICE_TYPE=MKP   # MKT | MKP | LMT
SHIOAJI_PROTECTIVE_LIMIT_OFFSET_POINTS=2
SHIOAJI_CA_PATH=          # Path to .pfx certificate file
SHIOAJI_CA_PASSWORD=

# --- Rithmic / Lucid ---
RITHMIC_USER=
RITHMIC_PASSWORD=
RITHMIC_SYSTEM_NAME=Rithmic Test
RITHMIC_APP_NAME=my_trading_bot
RITHMIC_URL=rituz00100.rithmic.com:443

# --- Webhook Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=
WEBHOOK_ALLOW_LEGACY_SECRET_HEADER=false   # Keep false in production

# --- Admin / Control Plane ---
# Required for /risk, /risk/resume, /trades/*, /positions
ADMIN_SECRET=

# --- Risk Management ---
RISK_MAX_DAILY_LOSS=50000        # Max daily loss in $ (absolute)
RISK_MAX_DAILY_LOSS_PCT=0.05     # Max daily loss as % of capital
RISK_MAX_POSITION_SIZE=10        # Max contracts per broker
RISK_MAX_ORDER_QTY=5             # Max contracts per single order
RISK_MAX_DRAWDOWN_PCT=0.15       # Drawdown circuit breaker (%)
RISK_COOLDOWN_AFTER_CONSECUTIVE_LOSSES=3
RISK_COOLDOWN_SECONDS=300        # Cooldown duration (seconds)
RISK_INITIAL_CAPITAL=1000000     # Starting capital

# --- Notifications ---
# Telegram: talk to @BotFather to create a bot and get a token
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LINE Notify: https://notify-bot.line.me/
LINE_NOTIFY_TOKEN=

# --- Logging ---
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL
